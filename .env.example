# Stratageo Site Suitability Portal - Environment Variables
#
# Copy this file to .env and fill in values.
# These variables are used by the Vite frontend build.

# App mode: 'demo' (default) or 'live'
# Demo mode uses pre-built scenarios and template explanations.
# Live mode calls OSM APIs + optional AI backend.
VITE_APP_MODE=demo

# URL of the AI backend proxy (only needed in live mode)
# This should point to your deployed serverless functions.
# Example: https://your-app.vercel.app
# Leave empty for demo-only deployment.
VITE_AI_BACKEND_URL=
